try:
    note = input("Please enter a short message: ")

    with open("notes.txt", "w") as file:
        file.write(note + "\n")
    print("Your message has been saved to notes.txt.")

    print("The system is reading the file to confirm it was saved correctly...")
   
    with open("notes.txt", "r") as file:
        content = file.read()
        print("== Content of notes.txt: ==")
        print(content)

    new_message = input("Please enter another message to append to the file: ") 

    with open("notes.txt", "a") as file:
        file.write(new_message + "\n")
    print("Your new message has been appended to notes.txt.")

except FileNotFoundError:
    print("Error! The file notes.txt was not found.")

except IOError:
    print("An error occurred while handling the file.")
